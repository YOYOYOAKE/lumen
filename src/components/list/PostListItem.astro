---
import { getTagSlug, type ResolvedPost } from '~/lib/content'
import { formatDate, toDateTimeISO } from '~/lib/utils'

interface Props {
  post: ResolvedPost
  index: number
  tagSlug?: string
}

const { post, index, tagSlug } = Astro.props
const href = tagSlug ? `${post.href}?tag=${tagSlug}` : post.href
const tagLinks = await Promise.all(
  post.data.tags.map(async (tag) => ({ name: tag, slug: await getTagSlug(tag) })),
)
const topText = 'TOP'
const unfinishedText = 'Draft'
const tagBadge =
  'bg-muted/40 text-muted-foreground hover:bg-muted/60 hover:text-foreground border border-transparent'
const recommendBadge =
  'border border-transparent bg-gradient-to-r from-slate-500/15 via-blue-500/15 to-indigo-500/15 text-slate-700 dark:text-slate-300 hover:from-slate-500/25 hover:via-blue-500/25 hover:to-indigo-500/25'
---

<div
  class="group relative block py-6 border-b border-border/60 last:border-none fade-up"
  style={`animation-delay: ${index * 100}ms`}
>
  <article
    class="relative z-1 flex flex-col gap-2 transform transition-transform duration-300 group-hover:translate-x-4"
  >
    <div class="flex sm:items-center gap-2 sm:gap-3 text-sm text-muted-foreground">
      <span class="inline-flex items-center gap-1.5">
        <span class="icon-[ph--calendar-blank] size-3.5 sm:size-4"></span>
        <time datetime={toDateTimeISO(post.data.createdAt)} class="text-xs sm:text-sm">
          {formatDate(post.data.createdAt, 'iso')}
        </time>
      </span>
    </div>

    <a href={href} class="block">
      <div
        class="text-base font-semibold text-foreground leading-tight group-hover:text-primary transition-colors line-clamp-2"
      >
        {post.data.title}
      </div>
      {
        post.data.description && (
          <p class="mt-1 text-sm text-muted-foreground/90 leading-5 line-clamp-2">
            {post.data.description}
          </p>
        )
      }
    </a>

    {
      (post.data.top || post.data.tags?.length || post.data.completed === false) && (
        <div class="flex flex-wrap gap-1.5">
          {post.data.top && (
            <span
              class:list={[
                'inline-flex items-center font-medium transition-colors duration-200 select-none text-xs px-2 py-0.5 gap-1',
                recommendBadge,
              ]}
              title="Top"
            >
              <span class="icon-[garden--sparkle-fill-16]"></span>
              <span class="font-semibold tracking-wide">{topText}</span>
            </span>
          )}
          {post.data.completed === false && (
            <span
              class:list={[
                'inline-flex items-center font-medium transition-colors duration-200 select-none text-xs px-2 py-0.5 gap-1',
                tagBadge,
              ]}
              title={unfinishedText}
            >
              {unfinishedText}
            </span>
          )}
          {tagLinks.slice(0, 5).map((tag) => (
            <a
              href={`/tags/${tag.slug}`}
              aria-label={`View posts tagged with ${tag.name}`}
              class:list={[
                'inline-flex items-center font-medium transition-colors duration-200 select-none text-xs px-2 py-0.5 gap-1',
                tagBadge,
              ]}
            >
              <span class="icon-[heroicons--hashtag-16-solid]"></span>
              {tag.name}
            </a>
          ))}
          {(post.data.tags?.length ?? 0) > 5 && (
            <span class="text-xs text-muted-foreground/60">
              +{(post.data.tags?.length ?? 0) - 5} more
            </span>
          )}
        </div>
      )
    }
  </article>

  {
    post.data.top && (
      <span class="absolute right-2 sm:right-4 top-1/2 -translate-y-1/2 -translate-x-4 size-16 sm:size-20 opacity-0 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 text-primary/10 dark:text-primary/20 icon-[solar--star-rainbow-bold-duotone]"></span>
    )
  }

  <div
    class="absolute left-0 top-0 h-full w-0.5 sm:w-1 scale-y-0 bg-accent/80 transition-transform duration-300 group-hover:scale-y-100"
  />
</div>
