---
import type { SkillItem, SkillsConfig } from '~/site.config'

interface Props {
  config: SkillsConfig
}

const { config } = Astro.props

function duplicate(items: SkillItem[]): SkillItem[] {
  return [...items, ...items, ...items, ...items]
}
---

<div class="py-8 pb-10 px-6 max-md:px-6 fade-up">
  <div class="px-2 max-md:px-0">
    <h2 class="text-2xl sm:text-3xl tracking-tight">{config.title}</h2>
    <p class="text-muted-foreground mb-6 mt-1">{config.description}</p>
  </div>
  <div class="relative py-2 px-2 max-md:px-0">
    {
      config.rows.map((row) => (
        <div class="relative w-full overflow-hidden my-4">
          <div
            class:list={[
              'flex w-max will-change-transform safari-only',
              row.direction === 'right'
                ? 'animate-[scroll-reverse_30s_linear_infinite]'
                : 'animate-[scroll_30s_linear_infinite]',
            ]}
            style="transform: translateZ(0)"
          >
            {duplicate(row.items).map((item) => (
              <span class="safari-item flex items-center gap-2 px-5 py-2 mx-2 rounded-full border border-border bg-accent text-foreground whitespace-nowrap dark:shadow-md transition-colors">
                <span class:list={['flex items-center justify-center w-5 h-5', item.icon]}></span>
                <span class="font-sans text-sm font-medium">{item.name}</span>
              </span>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</div>
