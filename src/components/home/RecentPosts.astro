---
import type { ResolvedPost } from '~/lib/content'
import PostListItem from '~/components/list/PostListItem.astro'

interface Props {
  title: string
  subtitle: string
  posts: ResolvedPost[]
}

const { title, subtitle, posts } = Astro.props
---

<div class="py-8 pb-10 px-6 sm:px-8 fade-up">
  <h2 class="text-2xl sm:text-3xl tracking-tight">{title}</h2>
  <p class="text-muted-foreground mb-6 mt-1">{subtitle}</p>
  <div>
    {posts.map((post, index) => <PostListItem post={post} index={index} />)}
  </div>
</div>
