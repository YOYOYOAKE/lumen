---
import { getTagSlug, type ResolvedPost } from '~/lib/content'
import { formatDate } from '~/lib/utils'

interface Props {
  post: ResolvedPost
}

const { post } = Astro.props
const tagLinks = await Promise.all(
  post.data.tags.map(async (tag) => ({ name: tag, slug: await getTagSlug(tag) })),
)
const topText = 'TOP'
const unfinishedText = 'Draft'
const tagBadge =
  'bg-muted/40 text-muted-foreground hover:bg-muted/60 hover:text-foreground border border-transparent'
const recommendBadge =
  'border border-transparent bg-gradient-to-r from-slate-500/15 via-blue-500/15 to-indigo-500/15 text-slate-700 dark:text-slate-300 hover:from-slate-500/25 hover:via-blue-500/25 hover:to-indigo-500/25'
const badgeSize = 'text-xs px-2 py-0.5 gap-1'
---

<header>
  <div class="space-y-4 md:space-y-5">
    {post.data.description && <p class="text-sm text-muted-foreground/90 leading-relaxed">{post.data.description}</p>}

    <div class="text-xl lg:text-2xl font-semibold leading-tight">
      {post.data.title}
    </div>

    <div class="flex flex-wrap items-center gap-3 sm:gap-4 text-sm text-muted-foreground/85">
      <div class="flex items-center gap-1.5">
        <span class="icon-[ph--calendar-blank] w-4 h-4 opacity-85"></span>
        <time datetime={post.data.createdAt.toISOString()}>
          {formatDate(post.data.createdAt, 'iso')}
        </time>
      </div>
      {
        post.data.updatedAt && (
          <div class="flex items-center gap-1.5">
            <span class="icon-[ph--pencil-simple] w-4 h-4 opacity-85"></span>
            <time datetime={post.data.updatedAt.toISOString()}>
              {formatDate(post.data.updatedAt, 'iso')}
            </time>
          </div>
        )
      }
      <div class="flex items-center gap-1.5">
        <span class="icon-[ph--book-open-text] w-4 h-4 opacity-85"></span>
        <span>{post.words} words</span>
      </div>
    </div>

    {
      (post.data.top || tagLinks.length || post.data.completed === false) && (
        <div class="flex gap-2 sm:gap-2.5 lg:gap-3 flex-wrap">
          {post.data.top && (
            <span
              class:list={[
                'inline-flex items-center font-medium transition-colors duration-200 select-none',
                badgeSize,
                recommendBadge,
              ]}
              title="Top"
            >
              <span class="icon-[garden--sparkle-fill-16]"></span>
              <span class="font-semibold tracking-wide">{topText}</span>
            </span>
          )}
          {post.data.completed === false && (
            <span
              class:list={[
                'inline-flex items-center font-medium transition-colors duration-200 select-none',
                badgeSize,
                tagBadge,
              ]}
              title={unfinishedText}
            >
              {unfinishedText}
            </span>
          )}
          {tagLinks.map((tag) => (
            <a
              href={`/tags/${tag.slug}`}
              aria-label={`View posts tagged with ${tag.name}`}
              class:list={[
                'inline-flex items-center font-medium transition-colors duration-200 select-none',
                badgeSize,
                tagBadge,
              ]}
            >
              <span class="icon-[heroicons--hashtag-16-solid]"></span>
              {tag.name}
            </a>
          ))}
        </div>
      )
    }
  </div>
  <div class="border-b border-border/60 my-8 sm:my-10 lg:my-12" />
</header>
