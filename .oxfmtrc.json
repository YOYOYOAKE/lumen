{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "jsxSingleQuote": true,
  "semi": false,
  "tabWidth": 2,
  "useTabs": false,
  "ignorePatterns": [
    "dist/**",
    "node_modules/**",
    "public/fonts/**",
    "test-results/**",
    "**/*.md",
    "**/*.css"
  ],
  "overrides": [
    {
      "files": ["*.astro"],
      "options": {
        "embeddedLanguageFormatting": "auto"
      }
    }
  ]
}
